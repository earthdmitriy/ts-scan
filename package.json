{
  "name": "ts-scan",
  "version": "0.1.3",
  "description": "CLI/MCP tool providing TypeScript code intelligence via the TypeScript Language Service. Analyze exports, imports, resolve symbols, and check type errors.",
  "keywords": [
    "typescript",
    "cli",
    "mcp",
    "code-analysis",
    "type-checking",
    "language-service",
    "model-context-protocol",
    "code-intelligence",
    "static-analysis"
  ],
  "type": "module",
  "scripts": {
    "lint": "npx tsc --noEmit",
    "prettier": "prettier --log-level warn --write \"src/**/*.ts\"",
    "build": "rm -rf dist && npx tsc && npm run copy",
    "copy": "node scripts/copy-docs.js",
    "all": "npm run format && npm run install-local",
    "test": "vitest",
    "test:run": "vitest run",
    "install-local": "npm run build && npm run test:run &&  npm install -g .",
    "remove-local": "npm uninstall -g ts-scan"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earthdmitriy/ts-scan"
  },
  "bin": {
    "ts-scan": "./dist/cli.js"
  },
  "author": "earthdmitriy",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "typescript": "^6.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ts-morph": "^28.0.0",
    "tslib": "^2.8.1",
    "typed-pipe": "^0.2.0",
    "zod": "^3.24.0"
  }
}

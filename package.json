{
  "name": "ts-scan",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.ts\"",
    "build": "npx tsc && npm run copy",
    "copy": "node scripts/copy-docs.js",
    "all": "npm run format && npm run install-local",
    "test": "vitest",
    "test:run": "vitest run",
    "install-local": "npm run test:run && npm run build && npm install -g .",
    "remove-local": "npm uninstall -g ts-scan"
  },
  "bin": {
    "ts-scan": "./dist/cli.js"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ts-morph": "^28.0.0",
    "tslib": "^2.8.1",
    "typed-pipe": "^0.2.0",
    "zod": "^3.24.0"
  }
}
